<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">



        <!-- ══ Template 1 — Employee submits → HR notified ══ -->
        <record id="email_template_submit_to_hr" model="mail.template">
            <field name="name">PCR: New Submission - HR</field>
            <field name="model_id" ref="employee_profile_change_request.model_hr_profile_change_request"/>
            <field name="subject">New Profile Change Request: {{ object.name }} - {{ object.employee_id.name }}</field>
            <field name="email_to">{{ object.employee_id.department_id.manager_id.work_email or 'kondavenianil93@gmail.com' }}</field>
            <field name="email_from">notifications@techcarrot-fz-llc1.odoo.com</field>
            <field name="body_html" type="html">
                <div style="font-family:Arial,sans-serif;max-width:620px;margin:auto;border:1px solid #ddd;border-radius:8px;overflow:hidden;">
                    <div style="background:#4e73df;padding:24px 28px;">
                        <h2 style="color:white;margin:0;font-size:20px;">New Profile Change Request</h2>
                        <p style="color:#c8d8ff;margin:6px 0 0;font-size:13px;">Action required - please review and approve or reject</p>
                    </div>
                    <div style="padding:28px;background:#f9f9f9;">
                        <p>Dear HR Team,</p>
                        <p>An employee has submitted a profile update request through the self-service portal.</p>
                        <table style="width:100%;border-collapse:collapse;margin:20px 0;background:white;">
                            <tr style="background:#eef2ff;">
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;width:38%;">Reference</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.name"/></td>
                            </tr>
                            <tr>
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;">Employee</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.employee_id.name"/></td>
                            </tr>
                            <tr style="background:#eef2ff;">
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;">Department</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.department_id.name or 'N/A'"/></td>
                            </tr>
                            <tr>
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;">Submitted On</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.submission_date"/></td>
                            </tr>
                        </table>
                        <p style="font-size:12px;color:#999;text-align:center;">
                            Go to: Odoo Backend - Human Resources - Profile Change Requests
                        </p>
                    </div>
                    <div style="background:#e8e8e8;padding:14px 28px;text-align:center;font-size:11px;color:#888;">
                        Automated notification - Employee Self Service Portal
                    </div>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>

        <!-- ══ Template 2 — HR approves → Employee notified ══ -->
        <record id="email_template_approved_to_employee" model="mail.template">
            <field name="name">PCR: Approved - Employee</field>
            <field name="model_id" ref="employee_profile_change_request.model_hr_profile_change_request"/>
            <field name="subject">Your Profile Update Has Been Approved - {{ object.name }}</field>
            <field name="email_to">{{ object.employee_id.work_email or object.employee_id.private_email or 'kondavenianil93@gmail.com' }}</field>
            <field name="email_from">notifications@techcarrot-fz-llc1.odoo.com</field>
            <field name="body_html" type="html">
                <div style="font-family:Arial,sans-serif;max-width:620px;margin:auto;border:1px solid #ddd;border-radius:8px;overflow:hidden;">
                    <div style="background:#1cc88a;padding:24px 28px;">
                        <h2 style="color:white;margin:0;font-size:20px;">Profile Update Approved</h2>
                        <p style="color:#c8fff0;margin:6px 0 0;font-size:13px;">Your information has been successfully updated</p>
                    </div>
                    <div style="padding:28px;background:#f9f9f9;">
                        <p>Dear <strong><t t-out="object.employee_id.name"/></strong>,</p>
                        <p>Your profile change request has been <strong style="color:#1cc88a;">approved</strong> by HR. Your employee record has been updated with all submitted information.</p>
                        <table style="width:100%;border-collapse:collapse;margin:20px 0;background:white;">
                            <tr style="background:#eefaf5;">
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;width:38%;">Reference</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.name"/></td>
                            </tr>
                            <tr>
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;">Approved By</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.reviewed_by.name"/></td>
                            </tr>
                            <tr style="background:#eefaf5;">
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;">Approved On</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.review_date"/></td>
                            </tr>
                        </table>
                        <div style="text-align:center;margin:28px 0 8px;">
                            <a href="/my/employee/personal"
                               style="background:#1cc88a;color:white;padding:13px 32px;border-radius:6px;text-decoration:none;font-weight:bold;font-size:15px;display:inline-block;">
                                View My Profile
                            </a>
                        </div>
                    </div>
                    <div style="background:#e8e8e8;padding:14px 28px;text-align:center;font-size:11px;color:#888;">
                        Automated notification - Employee Self Service Portal
                    </div>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>

        <!-- ══ Template 3 — HR rejects → Employee notified ══ -->
        <record id="email_template_rejected_to_employee" model="mail.template">
            <field name="name">PCR: Rejected - Employee</field>
            <field name="model_id" ref="employee_profile_change_request.model_hr_profile_change_request"/>
            <field name="subject">Your Profile Update Needs Correction - {{ object.name }}</field>
            <field name="email_to">{{ object.employee_id.work_email or object.employee_id.private_email or 'kondavenianil93@gmail.com' }}</field>
            <field name="email_from">notifications@techcarrot-fz-llc1.odoo.com</field>
            <field name="body_html" type="html">
                <div style="font-family:Arial,sans-serif;max-width:620px;margin:auto;border:1px solid #ddd;border-radius:8px;overflow:hidden;">
                    <div style="background:#e74a3b;padding:24px 28px;">
                        <h2 style="color:white;margin:0;font-size:20px;">Profile Update Needs Correction</h2>
                        <p style="color:#ffd5d5;margin:6px 0 0;font-size:13px;">Please review the reason and resubmit</p>
                    </div>
                    <div style="padding:28px;background:#f9f9f9;">
                        <p>Dear <strong><t t-out="object.employee_id.name"/></strong>,</p>
                        <p>Your profile change request has been <strong style="color:#e74a3b;">rejected</strong> by HR. Please review the reason below and resubmit.</p>
                        <table style="width:100%;border-collapse:collapse;margin:20px 0;background:white;">
                            <tr style="background:#fef5f5;">
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;width:38%;">Reference</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.name"/></td>
                            </tr>
                            <tr>
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;">Rejected By</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.reviewed_by.name"/></td>
                            </tr>
                            <tr style="background:#fef5f5;">
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;">Rejected On</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;"><t t-out="object.review_date"/></td>
                            </tr>
                            <tr>
                                <td style="padding:10px 14px;border:1px solid #ddd;font-weight:bold;vertical-align:top;">Reason</td>
                                <td style="padding:10px 14px;border:1px solid #ddd;color:#e74a3b;font-weight:600;">
                                    <t t-out="object.rejection_reason or 'No reason provided.'"/>
                                </td>
                            </tr>
                        </table>
                        <div style="text-align:center;margin:28px 0 8px;">
                            <a href="/my/employee/personal"
                               style="background:#e74a3b;color:white;padding:13px 32px;border-radius:6px;text-decoration:none;font-weight:bold;font-size:15px;display:inline-block;">
                                Go to My Profile
                            </a>
                        </div>
                    </div>
                    <div style="background:#e8e8e8;padding:14px 28px;text-align:center;font-size:11px;color:#888;">
                        Automated notification - Employee Self Service Portal
                    </div>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>

    </data>
</odoo>